{
  "name": "handwerker-software",
  "version": "2.3.6",
  "description": "Handwerker-Software — Angebote, Rechnungen, Terminplanung, Kundenverwaltung, Buchhaltung",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac --win",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "test": "node --test ./tests/*.test.js"
  },
  "build": {
    "appId": "de.handwerker-software.app",
    "productName": "Handwerker-Software",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "server/**/*.js",
      "server/package.json"
    ],
    "asarUnpack": [
      "server/**/*"
    ],
    "mac": {
      "category": "public.app-category.business",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "dmg": {
      "title": "Handwerker-Software",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Handwerker-Software"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Office"
    }
  },
  "author": "Handwerker Software",
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "nodemailer": "^9.0.3",
    "pdfkit": "^0.15.0",
    "puppeteer-core": "^25.3.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "electron": "^30.0.0",
    "electron-builder": "^24.0.0"
  }
}
